{
  "name": "@carllee1983/taskcli",
  "version": "0.5.1",
  "description": "在任何 repo 的 .taskcli/ 資料夾中，以「draft → 本地 HTML 審閱 → 正式 task」流程建立並追蹤 task 的 CLI 工具",
  "license": "MIT",
  "author": "Carl Lee",
  "type": "module",
  "bin": {
    "taskcli": "dist/cli.js"
  },
  "files": [
    "dist/cli.js",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/CarlLee1983/TaskCli.git"
  },
  "homepage": "https://github.com/CarlLee1983/TaskCli#readme",
  "bugs": {
    "url": "https://github.com/CarlLee1983/TaskCli/issues"
  },
  "keywords": [
    "cli",
    "task",
    "taskcli",
    "task-management",
    "todo",
    "draft",
    "workflow"
  ],
  "scripts": {
    "dev": "bun run src/cli.ts",
    "test": "bun test",
    "build": "bun build src/cli.ts --target node --outfile dist/cli.js --packages external",
    "compile": "bun build src/cli.ts --compile --outfile dist/taskcli",
    "prepublishOnly": "bun run build"
  },
  "devDependencies": {
    "bun-types": "^1.3.11"
  },
  "dependencies": {
    "@slack/bolt": "^4.7.3"
  }
}
